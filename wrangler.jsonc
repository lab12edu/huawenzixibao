{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "webapp",
  "compatibility_date": "2026-03-07",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ]
  // GEMINI_API_KEY is stored as a Cloudflare Secret — never in this file.
  // To set it in production:
  //   npx wrangler pages secret put GEMINI_API_KEY --project-name webapp
  // For local development it is read from .dev.vars (git-ignored).
}
